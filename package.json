{
  "name": "copyparty-client",
  "version": "1.0.0",
  "description": "Client for Copyparty",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.xxvii.copyparty-client",
    "productName": "Copyparty Client",
    "win": {
      "icon": "icon.png",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "files": [
      "main.js",
      "prompt.html",
      "preload.js",
      "package.json",
      "icon.png"
    ]
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  }
}